# Copia este archivo como .env y rellena los valores.
# Las variables EXPO_PUBLIC_* se incrustan en la app al compilar.

# --- Firebase (mismos valores que la web, ver README raíz) ---
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- Google Sign-In (Google Cloud Console → Credenciales) ---
# ID de cliente OAuth de tipo "Web" (Firebase lo crea automáticamente)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# ID de cliente OAuth de tipo "Android" (package com.rcv.tracker + SHA-1 de tu keystore)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# --- Strava (https://www.strava.com/settings/api) ---
EXPO_PUBLIC_STRAVA_CLIENT_ID=
EXPO_PUBLIC_STRAVA_CLIENT_SECRET=
