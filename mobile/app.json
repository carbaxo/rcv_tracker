{
  "expo": {
    "name": "RCV Tracker",
    "slug": "rcv-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "rcvtracker",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a0f14",
    "platforms": ["android"],
    "android": {
      "package": "com.rcv.tracker",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_EXERCISE_ROUTES",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_TOTAL_CALORIES_BURNED"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "RCV Tracker usa tu ubicación para grabar la ruta de tus entrenamientos de cardio.",
          "locationAlwaysAndWhenInUsePermission": "RCV Tracker usa tu ubicación en segundo plano para seguir grabando la ruta con la pantalla apagada.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-secure-store",
      "expo-task-manager",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "compileSdkVersion": 35,
            "targetSdkVersion": 34
          }
        }
      ],
      "./plugins/withHealthConnect.js"
    ]
  }
}
